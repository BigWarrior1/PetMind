# =============================================
# Alibaba Bailian Platform Configuration
# =============================================
# Get your API key at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-api-key-here

# =============================================
# Database Configuration (Development Stage)
# =============================================
DATABASE_URL=sqlite:///./pet_health.db

# =============================================
# Vector Database Configuration
# =============================================
CHROMA_PERSIST_DIR=./chroma_db

# =============================================
# Service Configuration
# =============================================
API_PORT=8000
LOG_LEVEL=INFO

# =============================================
# Model Configuration
# =============================================
# LLM model name (options: qwen-plus, qwen-max, qwen-turbo)
LLM_MODEL=qwen-plus
# Multimodal model name
VL_MODEL=qwen-vl-plus
# Embedding model name
EMBEDDING_MODEL=text-embedding-v3

# =============================================
# LLM Parameters
# =============================================
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# =============================================
# RAG Parameters
# =============================================
CHUNK_SIZE=500
RETRIEVER_K=5
RETRIEVER_SCORE_THRESHOLD=0.5
