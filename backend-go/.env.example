# PetMind Go 后端环境变量配置
# 复制此文件为 .env 并填写实际值
# 环境变量会覆盖 config.yaml 中的配置

# JWT 密钥（生产环境必须修改）
PETMIND_JWT_SECRET="your-secret-key-change-in-production"

# 数据库配置
PETMIND_DB_TYPE="sqlite"
PETMIND_DB_PATH="./data/petmind.db"

# PostgreSQL 配置（如果使用 PostgreSQL）
# PETMIND_DB_HOST="localhost"
# PETMIND_DB_PORT="5432"
# PETMIND_DB_USER="postgres"
# PETMIND_DB_PASSWORD="postgres"
# PETMIND_DB_NAME="petmind"

# AI 服务配置
PETMIND_AI_API_URL="http://localhost:8000/api/v1"

# 文件上传配置
PETMIND_UPLOAD_DIR="./data/uploads"

# 服务器端口
PETMIND_PORT="8080"
