# PetMind Go 后端环境变量配置

# JWT 密钥（生产环境必须修改）
PETMIND_JWT_SECRET="your-jwt-secret-change-in-production"

# 数据库配置
PETMIND_DB_TYPE="postgres"
PETMIND_DB_PATH="./data/petmind.db"
PETMIND_DB_HOST="localhost"
PETMIND_DB_PORT="5432"
PETMIND_DB_USER="postgres"
PETMIND_DB_PASSWORD="your-db-password"
PETMIND_DB_NAME="petmind"

# AI 服务配置
PETMIND_AI_API_URL="http://localhost:8000/api/v1"

# 文件上传配置
PETMIND_UPLOAD_DIR="./data/uploads"

# 服务器端口
PETMIND_PORT="8080"
